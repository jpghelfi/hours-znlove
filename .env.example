# Notion internal integration token (starts with "ntn_" or "secret_")
# Create at https://www.notion.so/my-integrations
NOTION_TOKEN=

# The Notion page the databases will be created under.
# Create a page in Notion (e.g. "Hours Tracker"), share it with your integration,
# then paste the page URL OR the 32-char page id here.
NOTION_PARENT_PAGE=

