# --- Notion integration (data access) ---
# Internal integration secret, starts with "ntn_". Create at
# https://www.notion.so/my-integrations
NOTION_TOKEN=

# The Notion page the databases live under (URL or 32-char id). Only needed to
# run src/setup_databases.py; not needed by the web app.
NOTION_PARENT_PAGE=

# Database/data-source ids. Written to databases.json by setup_databases.py for
# local use. On a deploy host (no file), set these instead:
# PROJECTS_DS_ID=
# TIME_ENTRIES_DS_ID=
# PROJECTS_DB_ID=
# TIME_ENTRIES_DB_ID=

# --- Web app: Notion OAuth login ---
# Make the integration "public" (Distribution tab) to get these, and set the
# redirect URI to  https://<your-host>/auth/callback
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=

# Comma-separated emails allowed to sign in. Everyone else is rejected.
ALLOWED_EMAILS=you@znlove.xyz, teammate@znlove.xyz

# Random secret for signing session cookies (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`)
SESSION_SECRET=

# Local dev only: set to 1 to bypass login. NEVER set in production.
# AUTH_DISABLED=1
